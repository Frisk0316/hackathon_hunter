# PredictPulse Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic Claude API Key (for AI-powered analysis)
# Get yours at: https://console.anthropic.com/
# Optional: falls back to template-based analysis without it
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# FRED API Key (for economic indicators)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
# Optional: pipeline works without it (uses Metaculus features only)
FRED_API_KEY=your_fred_api_key_here
