# PredictPulse Environment Variables
# Copy to .env and fill in your keys

# Metaculus API Token (free at https://metaculus.com/aib)
# Without this, synthetic data is used automatically.
METACULUS_TOKEN=your_metaculus_token_here

# Anthropic Claude API Key (for AI-powered analysis)
# Without this, template-based analysis is used.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
